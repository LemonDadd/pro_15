# ========== TqSdk 鉴权（必填） ==========
# 快期账号密码，注册地址：https://www.shinnytech.com/
TQ_AUTH_USER=your_tqsdk_username
TQ_AUTH_PASSWORD=your_tqsdk_password

# ========== 服务配置（可选） ==========
HOST=0.0.0.0
PORT=8000

# 启动超时时间（秒），默认 60
STARTUP_TIMEOUT=60

# wait_update 轮询间隔（秒），默认 5
UPDATE_LOOP_DEADLINE=5

# ========== 默认订阅（可选） ==========
# 引擎就绪后自动订阅的合约，逗号分隔
# A 股格式：SSE.600000（上交所）、SZSE.000001（深交所）
DEFAULT_STOCK_SYMBOLS=SSE.600000,SSE.600519,SZSE.000001

# 单次订阅上限
MAX_SUBSCRIBE_PER_REQUEST=50

# ========== 持久化（可选） ==========
# 是否将订阅列表持久化到本地 JSON（重启后自动恢复）
PERSIST_SUBSCRIPTIONS=false
# 持久化文件路径
SUBSCRIPTIONS_FILE=./subscriptions.json

# ========== API 鉴权（可选） ==========
# 非空时 REST 和 WebSocket 均需携带 X-API-Key 请求头
API_KEY=

# WebSocket 单连接队列最大长度（超出丢弃最旧消息）
MAX_WS_QUEUE_SIZE=100
